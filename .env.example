# ============================================================
# Special Sushi Poke — TEMPLATE variabili d'ambiente
# Copia questo file in `.env.local` e compila i valori reali.
# `.env.local` è in .gitignore (i segreti NON vanno committati).
# ============================================================

# Generazione immagini menu (kie.ai / Nano Banana)
KIEAI_API_KEY=

# Supabase (backend: ordini, dashboard admin)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Telegram (notifica ordini al titolare)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Sito
NEXT_PUBLIC_SITE_URL=https://special-sushi-poke.vercel.app

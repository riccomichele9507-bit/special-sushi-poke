# ============================================================
# Special Sushi Poke — TEMPLATE variabili d'ambiente
# Copia questo file in `.env.local` e compila i valori reali.
# `.env.local` è in .gitignore (i segreti NON vanno committati).
# ============================================================

# Generazione immagini menu (kie.ai / Nano Banana)
KIEAI_API_KEY=

# Supabase (backend: ordini, dashboard admin)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Google Maps (geocoding indirizzi consegna)
# Free tier: 10.000 geocoding chiamate/mese.
# Setup: console.cloud.google.com → Crea progetto → APIs & Services
#   → Library → "Geocoding API" → Enable
#   → Credentials → Create credentials → API key
#   → Restrict key: HTTP referrers o IP (server-side) + solo "Geocoding API"
#   → Quotas → imposta 500 req/giorno per sicurezza + alert billing
# Se vuoto, l'app usa OpenStreetMap Nominatim (gratis, meno preciso).
GOOGLE_MAPS_API_KEY=

# Stripe (pagamenti card + Apple Pay + Google Pay)
STRIPE_SECRET_KEY=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_WEBHOOK_SECRET=

# Resend (email transazionali al cliente)
RESEND_API_KEY=
RESEND_FROM_EMAIL=ordini@specialsushipoke.it

# CloudPRNT (stampante Star TSP143IV in cucina)
CLOUDPRNT_TOKEN=

# Sentry (error tracking opzionale)
SENTRY_DSN=

# Sito
NEXT_PUBLIC_SITE_URL=https://special-sushi-poke.vercel.app
